# NUSA-BENCH Server Configuration
PORT=5000
NODE_ENV=development
USE_LOCAL_DB=true

# Supabase Configuration
# Fill these with your actual Supabase credentials if you want to use the live database.
# If left as placeholders, the server will gracefully fallback to simulated local DB storage.
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App Environment
CLIENT_URL=http://localhost:5173
